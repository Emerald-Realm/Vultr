<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:tools="http://schemas.android.com/tools"
  android:id="@+id/wholeWidget"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/widget_card_background"
  android:gravity="center_vertical"
  android:orientation="horizontal"
  android:paddingStart="12dp"
  android:paddingEnd="8dp"
  android:paddingTop="6dp"
  android:paddingBottom="6dp"
  tools:ignore="Overdraw">

  <ImageView
    android:id="@+id/playPause"
    android:layout_width="40dp"
    android:layout_height="40dp"
    android:background="@android:color/transparent"
    android:contentDescription="@string/play_pause"
    android:padding="4dp"
    android:src="@drawable/ic_play_white_36dp" />

  <LinearLayout
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_marginStart="10dp"
    android:layout_weight="1"
    android:orientation="vertical">

    <TextView
      android:id="@+id/title"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:ellipsize="end"
      android:maxLines="1"
      android:textColor="@color/copy_primary_text_default_material_dark"
      android:textSize="14sp"
      android:textStyle="bold"
      tools:text="The Sandman: Act III" />

    <TextView
      android:id="@+id/author"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:ellipsize="end"
      android:maxLines="1"
      android:textColor="@color/copy_secondary_text_default_material_dark"
      android:textSize="12sp"
      tools:text="Neil Gaiman" />
  </LinearLayout>

  <ImageView
    android:id="@+id/rewind"
    android:layout_width="40dp"
    android:layout_height="40dp"
    android:layout_marginStart="4dp"
    android:background="@android:color/transparent"
    android:contentDescription="@string/rewind"
    android:padding="6dp"
    android:src="@drawable/ic_rewind_white_36dp" />

  <ImageView
    android:id="@+id/skipNext"
    android:layout_width="40dp"
    android:layout_height="40dp"
    android:background="@android:color/transparent"
    android:contentDescription="@string/next_track"
    android:padding="8dp"
    android:src="@drawable/ic_widget_skip_next" />

</LinearLayout>
